{
  "id" : "rubric-evaluation-pass",
  "version" : "1.0.0",
  "stateSchema" : {
    "variables" : [ {
      "name" : "topic",
      "type" : "STRING",
      "isInput" : true
    } ]
  },
  "startNode" : "draft",
  "agents" : {
    "writer" : {
      "id" : "writer",
      "role" : "writer",
      "model" : "stub",
      "temperature" : 0.7
    }
  },
  "nodes" : {
    "draft" : {
      "id" : "draft",
      "nodeType" : "STANDARD",
      "agentId" : "writer",
      "prompt" : "Write a comprehensive article about {topic}",
      "rubric" : "# Rubric: quality\n## Metadata\n- pass_threshold: 80.0\n## Criteria\n### Accuracy (weight: 3)\n- All facts and claims must be verifiable and correct\n### Clarity (weight: 2)\n- Clear and logical structure\n### Completeness (weight: 1)\n- All required topics covered",
      "transitionRules" : [ {
        "type" : "success",
        "targetNode" : "done"
      } ]
    },
    "done" : {
      "id" : "done",
      "nodeType" : "END",
      "status" : "SUCCESS"
    }
  }
}
