{
  "id" : "rubric-backtrack-critical",
  "version" : "1.0.0",
  "stateSchema" : {
    "variables" : [ {
      "name" : "topic",
      "type" : "STRING",
      "isInput" : true
    } ]
  },
  "startNode" : "research",
  "agents" : {
    "researcher" : {
      "id" : "researcher",
      "role" : "researcher",
      "model" : "stub",
      "temperature" : 0.5
    },
    "writer" : {
      "id" : "writer",
      "role" : "writer",
      "model" : "stub",
      "temperature" : 0.7
    }
  },
  "nodes" : {
    "research" : {
      "id" : "research",
      "nodeType" : "STANDARD",
      "agentId" : "researcher",
      "prompt" : "Research the topic: {topic}",
      "transitionRules" : [ {
        "type" : "success",
        "targetNode" : "draft"
      } ]
    },
    "draft" : {
      "id" : "draft",
      "nodeType" : "STANDARD",
      "agentId" : "writer",
      "prompt" : "Write an article based on the research",
      "rubric" : "# Rubric: quality\n## Metadata\n- pass_threshold: 70.0\n## Criteria\n### Quality (weight: 1)\n- Content must be well-structured and comprehensive",
      "transitionRules" : [ {
        "type" : "success",
        "targetNode" : "done"
      } ]
    },
    "done" : {
      "id" : "done",
      "nodeType" : "END",
      "status" : "SUCCESS"
    }
  }
}
