{
  "id" : "standard-output-params",
  "version" : "1.0.0",
  "stateSchema" : {
    "variables" : [ {
      "name" : "text",
      "type" : "STRING",
      "isInput" : true
    }, {
      "name" : "sentiment",
      "type" : "STRING",
      "isInput" : false
    }, {
      "name" : "confidence",
      "type" : "STRING",
      "isInput" : false
    }, {
      "name" : "keywords",
      "type" : "STRING",
      "isInput" : false
    } ]
  },
  "startNode" : "analyze",
  "agents" : {
    "analyzer" : {
      "id" : "analyzer",
      "role" : "analyzer",
      "model" : "stub",
      "temperature" : 0.3
    }
  },
  "nodes" : {
    "analyze" : {
      "id" : "analyze",
      "nodeType" : "STANDARD",
      "agentId" : "analyzer",
      "prompt" : "Analyze the sentiment of: {text}",
      "writes" : [ "sentiment", "confidence", "keywords" ],
      "transitionRules" : [ {
        "type" : "success",
        "targetNode" : "done"
      } ]
    },
    "done" : {
      "id" : "done",
      "nodeType" : "END",
      "status" : "SUCCESS"
    }
  }
}
